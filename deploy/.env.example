# Generate deploy/.env with ./generate-env.sh. Keep this value empty so a
# copied example cannot accidentally start ClickHouse with a known password.
OPEN_SPLUNK_CLICKHOUSE_PASSWORD=

# Host-side ports are optional. Both remain bound to 127.0.0.1.
# OPEN_SPLUNK_CLICKHOUSE_HTTP_PORT=8123
# OPEN_SPLUNK_CLICKHOUSE_NATIVE_PORT=9000
